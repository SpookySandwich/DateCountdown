<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DateCountdown.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid
        x:Name="RootGrid"
        Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Background="Transparent" />

        <Grid
            x:Name="CountdownSelectorFrame"
            Grid.Row="1"
            Canvas.ZIndex="1"
            Margin="32,8,32,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Visibility="Collapsed">
            <Grid.Transitions>
                <TransitionCollection>
                    <RepositionThemeTransition />
                </TransitionCollection>
            </Grid.Transitions>
            <ScrollViewer
                x:Name="CountdownSelectorRail"
                HorizontalAlignment="Stretch"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                PointerCanceled="CountdownSelectorRail_PointerCanceled"
                PointerMoved="CountdownSelectorRail_PointerMoved"
                PointerPressed="CountdownSelectorRail_PointerPressed"
                PointerReleased="CountdownSelectorRail_PointerReleased"
                PointerWheelChanged="CountdownSelectorRail_PointerWheelChanged"
                SizeChanged="CountdownSelectorRail_SizeChanged"
                VerticalScrollBarVisibility="Disabled"
                VerticalScrollMode="Disabled">
                <Grid x:Name="CountdownSelectorContentHost">
                    <StackPanel
                        x:Name="CountdownSelectorItems"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="18">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <RepositionThemeTransition />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <ScrollViewer
            x:Name="MainContentScroller"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <ScrollViewer.RenderTransform>
                <TranslateTransform />
            </ScrollViewer.RenderTransform>
            <StackPanel
                x:Name="MainContentPanel"
                MaxWidth="390"
                MinWidth="296"
                Padding="32,36,32,40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="26">
                <StackPanel
                    HorizontalAlignment="Stretch"
                    Spacing="4">
                    <TextBlock
                        x:Name="TextBlockDays"
                        x:Uid="DaysLeft"
                        MaxWidth="560"
                        MinWidth="296"
                        AutomationProperties.AccessibilityView="Content"
                        AutomationProperties.LiveSetting="Polite"
                        FontFamily="Segoe UI Variable Display, Segoe UI"
                        FontSize="72"
                        FontWeight="Light"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="TextBlockTitle"
                        MaxWidth="360"
                        AutomationProperties.AccessibilityView="Content"
                        FontSize="14"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Opacity="0.88"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Stretch"
                    Spacing="8">
                    <CalendarDatePicker
                        x:Name="DatePickerTargetDate"
                        AutomationProperties.AutomationId="TargetDatePicker"
                        DateChanged="DatePickerTargetDate_SelectedDateChanged"
                        HorizontalAlignment="Stretch" />
                    <TextBox
                        x:Name="TextBoxTitle"
                        AutomationProperties.AutomationId="CountdownTitleTextBox"
                        TextChanged="TextBoxTitle_TextChanged"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="8">
                    <StackPanel
                        x:Name="ToggleButtons"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="NotifyButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="StartupNotificationToggle"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="NotifyButton_Click">
                            <Button.RenderTransform>
                                <TranslateTransform />
                            </Button.RenderTransform>
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE7E7;" />
                        </Button>
                        <Button
                            x:Name="TileButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="GlanceSurfaceButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="TileButton_Click">
                            <Button.RenderTransform>
                                <TranslateTransform />
                            </Button.RenderTransform>
                            <FontIcon
                                x:Name="GlanceSurfaceIcon"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xECA5;" />
                        </Button>
                        <Button
                            x:Name="DeleteButton"
                            Width="40"
                            Height="40"
                            Opacity="0"
                            Padding="0"
                            AutomationProperties.AutomationId="DeleteCountdownButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="DeleteButton_Click"
                            IsHitTestVisible="False"
                            IsTabStop="False"
                            Visibility="Collapsed">
                            <Button.RenderTransform>
                                <TranslateTransform />
                            </Button.RenderTransform>
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE74D;" />
                        </Button>
                        <Button
                            x:Name="AddButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="AddCountdownButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="AddButton_Click">
                            <Button.RenderTransform>
                                <TranslateTransform />
                            </Button.RenderTransform>
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE710;" />
                        </Button>
                        <Button
                            x:Name="MoreButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="MoreButton"
                            Background="Transparent"
                            BorderThickness="0">
                            <Button.RenderTransform>
                                <TranslateTransform />
                            </Button.RenderTransform>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        x:Name="SettingsMenuItem"
                                        Click="SettingsMenuItem_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon
                                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                Glyph="&#xE713;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE712;" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer
            x:Name="SettingsContentScroller"
            Grid.Row="1"
            Canvas.ZIndex="2"
            Padding="18,4,18,32"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            SizeChanged="SettingsContentScroller_SizeChanged"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto"
            Visibility="Collapsed">
            <StackPanel
                x:Name="SettingsContentPanel"
                MaxWidth="640"
                MinWidth="360"
                HorizontalAlignment="Center"
                Spacing="28">
                <StackPanel
                    Spacing="16">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="SettingsBackButton"
                            Width="36"
                            Height="36"
                            Padding="0"
                            AutomationProperties.AutomationId="SettingsBackButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="SettingsBackButton_Click">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE72B;" />
                        </Button>
                        <TextBlock
                            x:Name="SettingsTitleText"
                            VerticalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Name="SettingsCountdownsHeaderText"
                            FontSize="14"
                            FontWeight="SemiBold" />
                        <Border
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            CornerRadius="6">
                            <Grid Padding="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="18"
                                    Glyph="&#xE8CB;"
                                    VerticalAlignment="Center" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock
                                        x:Name="SortCountdownsTitleText"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="SortCountdownsToggle"
                                    Grid.Column="2"
                                    Margin="16,0,0,0"
                                    MinWidth="0"
                                    OffContent=""
                                    OnContent=""
                                    Toggled="SortCountdownsToggle_Toggled" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Name="SettingsAppearanceHeaderText"
                            FontSize="14"
                            FontWeight="SemiBold" />
                        <Expander
                            x:Name="TextSizeExpander"
                            HorizontalAlignment="Stretch"
                            IsExpanded="False">
                            <Expander.Header>
                                <Grid MinHeight="56">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        FontSize="18"
                                        Glyph="&#xE790;"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        x:Name="TextSizeTitleText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel
                                Padding="56,0,16,18"
                                Spacing="14">
                                <Border
                                    Padding="16"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="6">
                                    <StackPanel
                                        HorizontalAlignment="Stretch"
                                        Spacing="4">
                                        <TextBlock
                                            x:Name="SettingsPreviewDaysText"
                                            MaxWidth="520"
                                            HorizontalAlignment="Center"
                                            FontFamily="Segoe UI Variable Display, Segoe UI"
                                            FontWeight="Light"
                                            TextAlignment="Center"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            x:Name="SettingsPreviewTitleText"
                                            HorizontalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Opacity="0.88"
                                            TextAlignment="Center"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        x:Name="DaysTextSizeLabelText"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Name="DaysTextSizeValueText"
                                        Grid.Column="1"
                                        Opacity="0.72" />
                                </Grid>
                                <Slider
                                    x:Name="DaysTextSizeSlider"
                                    SmallChange="1"
                                    StepFrequency="1"
                                    ValueChanged="DaysTextSizeSlider_ValueChanged" />

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        x:Name="TitleTextSizeLabelText"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Name="TitleTextSizeValueText"
                                        Grid.Column="1"
                                        Opacity="0.72" />
                                </Grid>
                                <Slider
                                    x:Name="TitleTextSizeSlider"
                                    SmallChange="1"
                                    StepFrequency="1"
                                    ValueChanged="TitleTextSizeSlider_ValueChanged" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Name="SettingsStartupHeaderText"
                            FontSize="14"
                            FontWeight="SemiBold" />
                        <Border
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            CornerRadius="6">
                            <Grid Padding="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="18"
                                    Glyph="&#xE8FB;"
                                    VerticalAlignment="Center" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock
                                        x:Name="OpenAtStartupTitleText"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="OpenAtStartupToggle"
                                    Grid.Column="2"
                                    Margin="16,0,0,0"
                                    MinWidth="0"
                                    OffContent=""
                                    OnContent=""
                                    Toggled="OpenAtStartupToggle_Toggled" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Name="SettingsAboutHeaderText"
                            FontSize="14"
                            FontWeight="SemiBold" />
                        <Border
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            CornerRadius="6">
                            <Grid Padding="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Grid.Column="0"
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Source="Assets/Square44x44Logo.targetsize-24.png" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock
                                        x:Name="AboutAppNameText"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="AboutVersionText"
                                    Grid.Column="2"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    Opacity="0.72" />
                            </Grid>
                        </Border>
                        <HyperlinkButton
                            x:Name="SourceCodeLinkButton"
                            Padding="0"
                            NavigateUri="https://github.com/SpookySandwich/DateCountdown" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
