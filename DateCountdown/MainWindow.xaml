<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DateCountdown.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Background="Transparent" />

        <Grid
            x:Name="CountdownSelectorFrame"
            Grid.Row="1"
            Margin="32,8,32,0"
            HorizontalAlignment="Stretch"
            Visibility="Collapsed">
            <ScrollViewer
                x:Name="CountdownSelectorRail"
                HorizontalAlignment="Stretch"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                PointerCanceled="CountdownSelectorRail_PointerCanceled"
                PointerMoved="CountdownSelectorRail_PointerMoved"
                PointerPressed="CountdownSelectorRail_PointerPressed"
                PointerReleased="CountdownSelectorRail_PointerReleased"
                PointerWheelChanged="CountdownSelectorRail_PointerWheelChanged"
                SizeChanged="CountdownSelectorRail_SizeChanged"
                VerticalScrollBarVisibility="Disabled"
                VerticalScrollMode="Disabled">
                <Grid x:Name="CountdownSelectorContentHost">
                    <StackPanel
                        x:Name="CountdownSelectorItems"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="18" />
                </Grid>
            </ScrollViewer>
        </Grid>

        <ScrollViewer
            Grid.Row="2"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <StackPanel
                MaxWidth="390"
                MinWidth="296"
                Padding="32,36,32,40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="26">
                <StackPanel
                    HorizontalAlignment="Stretch"
                    Spacing="4">
                    <TextBlock
                        x:Name="TextBlockDays"
                        x:Uid="DaysLeft"
                        MaxWidth="420"
                        MinWidth="296"
                        AutomationProperties.AccessibilityView="Content"
                        AutomationProperties.LiveSetting="Polite"
                        FontFamily="Segoe UI Variable Display, Segoe UI"
                        FontSize="72"
                        FontWeight="Light"
                        SizeChanged="TextBlockDays_SizeChanged"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="TextBlockTitle"
                        MaxWidth="360"
                        AutomationProperties.AccessibilityView="Content"
                        FontSize="14"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Opacity="0.88"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Stretch"
                    Spacing="8">
                    <CalendarDatePicker
                        x:Name="DatePickerTargetDate"
                        AutomationProperties.AutomationId="TargetDatePicker"
                        DateChanged="DatePickerTargetDate_SelectedDateChanged"
                        HorizontalAlignment="Stretch" />
                    <TextBox
                        x:Name="TextBoxTitle"
                        AutomationProperties.AutomationId="CountdownTitleTextBox"
                        TextChanged="TextBoxTitle_TextChanged"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="8">
                    <StackPanel
                        x:Name="ToggleButtons"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="NotifyButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="StartupNotificationToggle"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="NotifyButton_Click">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE7E7;" />
                        </Button>
                        <Button
                            x:Name="TileButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="GlanceSurfaceButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="TileButton_Click">
                            <FontIcon
                                x:Name="GlanceSurfaceIcon"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xECA5;" />
                        </Button>
                        <Button
                            x:Name="DeleteButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="DeleteCountdownButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="DeleteButton_Click">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE74D;" />
                        </Button>
                        <Button
                            x:Name="AddButton"
                            Width="40"
                            Height="40"
                            Padding="0"
                            AutomationProperties.AutomationId="AddCountdownButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="AddButton_Click">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE710;" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
